# Environment config for the meeting-prep pipeline. Copy to .env and adjust.

# LLM: local Qwen via Ollama (no API key needed; Ollama serves on localhost:11434).
# Used for both brief generation and the eval quality judge.
OLLAMA_MODEL=qwen3:14b
# OLLAMA_HOST=http://localhost:11434   # only set if Ollama isn't on the default host

# Embeddings: local sentence-transformers (no API key).
# The embedding model itself (BAAI/bge-base-en-v1.5) is set in config.py.
EMBEDDING_BACKEND=local

# Retrieval tuning (optional; sensible defaults live in config.py)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=150
# TOP_K=8
# RECENCY_HALF_LIFE_DAYS=30     # recency decay half-life in days; <=0 disables
# CANDIDATE_MULTIPLIER=5        # FAISS pool = TOP_K * this, then recency re-rank
# INTERNAL_EMAIL_DOMAIN=fastcode.ai

# Eval scoring split (overall = guideline * weight + quality * weight)
# EVAL_GUIDELINE_WEIGHT=0.6
# EVAL_QUALITY_WEIGHT=0.4

# Database connection (libpq URL); unset uses config.py's default
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lighthouse
